---
import type { Locale } from '../i18n';

interface Props {
  src: string;
  title: string;
  locale: Locale;
  height?: number;
}

const { src, title, locale, height = 720 } = Astro.props;
const fallback =
  locale === 'ja'
    ? '埋め込みが読み込めない場合は、直接サイトをご覧ください。'
    : "If the embed doesn't load, view the site directly.";
const viewOn = locale === 'ja' ? 'サイトを開く' : 'Open site';
---
<div
  class="embed-wrap border border-neutral-200 rounded-lg overflow-hidden bg-white relative"
  style={`height:${height}px`}
  data-src={src}
>
  <div class="embed-loading absolute inset-0 flex items-center justify-center text-sm text-ink-muted bg-white pointer-events-none">
    <div class="flex items-center gap-2">
      <span class="inline-block w-3 h-3 rounded-full bg-neutral-300 animate-pulse"></span>
      {locale === 'ja' ? '読み込み中…' : 'Loading…'}
    </div>
  </div>
  <iframe
    src={src}
    title={title}
    class="w-full h-full block border-0 relative z-10"
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    sandbox="allow-scripts allow-same-origin allow-popups allow-popups-to-escape-sandbox allow-forms"
    onload="this.parentElement.querySelector('.embed-loading')?.remove()"
  ></iframe>
  <div class="embed-fallback hidden absolute inset-0 p-5 flex flex-col gap-3 items-start justify-start bg-white text-sm z-20">
    <p class="text-ink-muted leading-relaxed">{fallback}</p>
    <a
      href={src}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-3 py-1.5 border border-ink rounded text-ink no-underline hover:bg-ink hover:text-white transition-colors"
    >
      {viewOn} →
    </a>
  </div>
</div>
<script is:inline>
  (() => {
    document.querySelectorAll('.embed-wrap').forEach((wrap) => {
      const iframe = wrap.querySelector('iframe');
      if (!iframe) return;
      let loaded = false;
      iframe.addEventListener('load', () => { loaded = true; });
      setTimeout(() => {
        if (!loaded) {
          const fb = wrap.querySelector('.embed-fallback');
          const loading = wrap.querySelector('.embed-loading');
          if (loading) loading.remove();
          if (fb) fb.classList.remove('hidden');
        }
      }, 6000);
    });
  })();
</script>
