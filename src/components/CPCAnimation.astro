<style>
  /*
    Faithful port of `motion-breathe-1` from symbol-emergence.net (Wix).
    Variables: --motion-breathe-x/y/z (direction), --motion-breathe-distance.
    On the source site the same animation runs for 5s linear infinite with
    distance 15px on `comp-lxcy2ot8` and 20px on `comp-lxcy2pfg`.
  */
  @keyframes motion-breathe-1 {
    0% {
      animation-timing-function: cubic-bezier(0.39, 0.575, 0.565, 1);
      transform: translate3d(0, 0, 0);
    }
    25% {
      animation-timing-function: cubic-bezier(0.445, 0.05, 0.55, 0.95);
      transform: translate3d(
        calc(var(--motion-breathe-x) * var(--motion-breathe-distance)),
        calc(var(--motion-breathe-y) * var(--motion-breathe-distance)),
        calc(var(--motion-breathe-z) * var(--motion-breathe-distance))
      );
    }
    75% {
      animation-timing-function: cubic-bezier(0.47, 0, 0.745, 0.715);
      transform: translate3d(
        calc(var(--motion-breathe-x) * -1 * var(--motion-breathe-distance)),
        calc(var(--motion-breathe-y) * -1 * var(--motion-breathe-distance)),
        calc(var(--motion-breathe-z) * -1 * var(--motion-breathe-distance))
      );
    }
    100% {
      transform: translate3d(0, 0, 0);
    }
  }
  .breathe-15,
  .breathe-20 {
    --motion-breathe-x: 0;
    --motion-breathe-y: 1;
    --motion-breathe-z: 0;
    transform-box: fill-box;
    transform-origin: center;
    will-change: transform;
    animation-duration: 5000ms;
    animation-delay: 1ms;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-name: motion-breathe-1;
  }
  .breathe-15 { --motion-breathe-distance: 15px; }
  .breathe-20 { --motion-breathe-distance: 20px; }
  @media (prefers-reduced-motion: reduce) {
    .breathe-15, .breathe-20 { animation: none; }
  }

  /* Cursor-driven parallax — gently shifts the breathe groups
     based on pointer position. Layered on top of the infinite
     motion-breathe-1 so the room feels alive even when idle. */
  .cpc-room {
    --cpc-px: 0;
    --cpc-py: 0;
  }
  .cpc-parallax {
    transform: translate3d(
      calc(var(--cpc-px) * var(--cpc-parallax-strength, 1)),
      calc(var(--cpc-py) * var(--cpc-parallax-strength, 1)),
      0
    );
    transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    will-change: transform;
  }
  .cpc-parallax-orange { --cpc-parallax-strength: 1.4; }
  .cpc-parallax-green  { --cpc-parallax-strength: 1.0; }
  @media (prefers-reduced-motion: reduce) {
    .cpc-parallax { transform: none; transition: none; }
  }
</style>

<script is:inline>
  (() => {
    const fig = document.querySelector('.cpc-room');
    if (!fig) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (!window.matchMedia('(hover: hover)').matches) return;

    const MAX_SHIFT_PX = 18;
    const EASE = 0.12;

    let targetX = 0, targetY = 0;
    let currentX = 0, currentY = 0;
    let rafId = null;
    let inView = true;

    const lerp = (a, b, t) => a + (b - a) * t;

    const apply = () => {
      fig.style.setProperty('--cpc-px', currentX.toFixed(2) + 'px');
      fig.style.setProperty('--cpc-py', currentY.toFixed(2) + 'px');
    };

    const tick = () => {
      currentX = lerp(currentX, targetX, EASE);
      currentY = lerp(currentY, targetY, EASE);
      apply();
      if (
        Math.abs(currentX - targetX) > 0.05 ||
        Math.abs(currentY - targetY) > 0.05
      ) {
        rafId = requestAnimationFrame(tick);
      } else {
        currentX = targetX;
        currentY = targetY;
        apply();
        rafId = null;
      }
    };

    const onMove = (e) => {
      if (!inView) return;
      const rect = fig.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const nx = (e.clientX - cx) / (window.innerWidth / 2);
      const ny = (e.clientY - cy) / (window.innerHeight / 2);
      const clamp = (v) => Math.max(-1, Math.min(1, v));
      targetX = clamp(nx) * MAX_SHIFT_PX;
      targetY = clamp(ny) * MAX_SHIFT_PX;
      if (rafId === null) rafId = requestAnimationFrame(tick);
    };

    const onLeave = () => {
      targetX = 0;
      targetY = 0;
      if (rafId === null) rafId = requestAnimationFrame(tick);
    };

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => { inView = entry.isIntersecting; });
      }, { rootMargin: '50px' });
      io.observe(fig);
    }

    window.addEventListener('mousemove', onMove, { passive: true });
    window.addEventListener('mouseleave', onLeave, { passive: true });
  })();
</script>
