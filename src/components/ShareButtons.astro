---
import { t, type Locale } from '../i18n';

interface Props {
  /** Canonical absolute URL of the page being shared */
  url: string;
  /** Plain text to pre-fill (without the URL — the intent URL appends it) */
  text: string;
  locale: Locale;
}

const { url, text, locale } = Astro.props;

const HANDLE = 'cpchub';
const xText = `${text} via @${HANDLE}`;
const bskyText = `${text}\n${url}`;

const xHref = `https://x.com/intent/post?text=${encodeURIComponent(xText)}&url=${encodeURIComponent(url)}`;
const bskyHref = `https://bsky.app/intent/compose?text=${encodeURIComponent(bskyText)}`;
---
<div class="flex items-center flex-wrap gap-2 text-sm">
  <span class="text-ink-muted mr-1">{t(locale, 'share.label')}:</span>

  <a
    href={xHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={t(locale, 'share.x')}
    class="inline-flex items-center gap-1.5 px-3 py-1.5 border border-neutral-300 rounded-full text-ink-muted hover:border-ink hover:text-ink no-underline transition-colors"
  >
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
    <span>X</span>
  </a>

  <a
    href={bskyHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={t(locale, 'share.bluesky')}
    class="inline-flex items-center gap-1.5 px-3 py-1.5 border border-neutral-300 rounded-full text-ink-muted hover:border-ink hover:text-ink no-underline transition-colors"
  >
    <svg class="w-3.5 h-3.5" viewBox="0 0 600 530" fill="currentColor" aria-hidden="true">
      <path d="M135.72 44.03C202.216 93.951 273.74 195.17 300 249.49c26.262-54.316 97.782-155.54 164.28-205.46C512.26 8.009 590-19.501 590 69.142c0 17.696-10.144 148.66-16.092 169.93-20.671 73.945-96.123 92.87-163.227 81.453 117.305 19.964 147.187 86.092 82.766 152.22-122.36 125.55-175.85-31.51-189.55-71.766-2.51-7.382-3.686-10.832-3.696-7.896-.01-2.936-1.187.514-3.697 7.896-13.69 40.255-67.18 197.317-189.54 71.766-64.422-66.128-34.54-132.255 82.766-152.22-67.105 11.418-142.557-7.508-163.228-81.453C20.144 217.802 10 86.838 10 69.142c0-88.643 77.74-61.133 125.72-25.112z"/>
    </svg>
    <span>Bluesky</span>
  </a>

  <button
    type="button"
    class="copy-link-btn inline-flex items-center gap-1.5 px-3 py-1.5 border border-neutral-300 rounded-full text-ink-muted hover:border-ink hover:text-ink transition-colors"
    data-copy-url={url}
    data-copied-label={t(locale, 'share.copied')}
    data-default-label={t(locale, 'share.copy')}
    aria-label={t(locale, 'share.copy')}
  >
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
    </svg>
    <span class="copy-link-label">{t(locale, 'share.copy')}</span>
  </button>
</div>

<script is:inline>
  (() => {
    const buttons = document.querySelectorAll('.copy-link-btn');
    if (!buttons.length) return;
    for (const btn of buttons) {
      btn.addEventListener('click', async () => {
        const url = btn.getAttribute('data-copy-url') || '';
        const copied = btn.getAttribute('data-copied-label') || 'Copied';
        const def = btn.getAttribute('data-default-label') || 'Copy link';
        const label = btn.querySelector('.copy-link-label');
        try {
          await navigator.clipboard.writeText(url);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = url;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand('copy'); } catch {}
          document.body.removeChild(ta);
        }
        if (label) {
          label.textContent = copied;
          btn.classList.add('text-ink', 'border-ink');
          setTimeout(() => {
            label.textContent = def;
            btn.classList.remove('text-ink', 'border-ink');
          }, 1600);
        }
      });
    }
  })();
</script>
