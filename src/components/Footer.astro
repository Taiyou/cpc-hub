---
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="border-t border-neutral-200 mt-auto">
  <div class="max-w-5xl mx-auto px-6 py-8 text-sm text-ink-muted flex flex-col gap-2 sm:flex-row sm:justify-between">
    <p>{t(locale, 'footer.note')}</p>
    <p>© {year} symbol-emergence hub</p>
  </div>
</footer>
