---
import Layout from '../Layout.astro';
import VideoCard, { type VideoItem } from '../VideoCard.astro';
import { t, type Locale } from '../../i18n';
import videosData from '../../data/videos.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const items = (videosData.items ?? []) as VideoItem[];
const fetchedAt = videosData.fetchedAt as string | null;
const fmtDateTime = (iso: string) =>
  new Date(iso).toLocaleString(locale === 'ja' ? 'ja-JP' : 'en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
---
<Layout locale={locale} pathWithoutLocale="/videos/" title={t(locale, 'videos.heading')}>
  <header class="py-8 border-b border-neutral-200 mb-8">
    <h1 class="text-3xl font-semibold mb-2">{t(locale, 'videos.heading')}</h1>
    <p class="text-ink-muted">{t(locale, 'videos.intro')}</p>
    {fetchedAt && (
      <p class="text-xs text-ink-muted mt-3">
        {t(locale, 'videos.last_updated')}: {fmtDateTime(fetchedAt)}
      </p>
    )}
  </header>

  {items.length === 0 ? (
    <p class="text-ink-muted">{t(locale, 'videos.empty')}</p>
  ) : (
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((v) => <VideoCard video={v} locale={locale} />)}
    </div>
  )}
</Layout>
