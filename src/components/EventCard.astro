---
import type { CollectionEntry } from 'astro:content';
import { localizedPath, t, type Locale } from '../i18n';

interface Props {
  event: CollectionEntry<'events'>;
  locale: Locale;
}

const { event, locale } = Astro.props;
const { data } = event;
const href = localizedPath(locale, `/events/${event.id}/`);
const title = locale === 'ja' && data.title_ja ? data.title_ja : data.title_en;
const description =
  locale === 'ja' && data.description_ja ? data.description_ja : data.description_en;
const isFallback =
  locale === 'ja' && (!data.title_ja || !data.description_ja);

const fmt = (d: Date) =>
  d.toLocaleDateString(locale === 'ja' ? 'ja-JP' : 'en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
const dateLabel =
  data.date_start.getTime() === data.date_end.getTime()
    ? fmt(data.date_start)
    : `${fmt(data.date_start)} – ${fmt(data.date_end)}`;
---
<a
  href={href}
  class="block border border-neutral-200 rounded-lg p-5 hover:border-ink transition-colors no-underline group"
>
  <div class="text-xs uppercase tracking-wider text-ink-muted mb-1">
    {data.type} · {data.language}
  </div>
  <h3 class="text-base font-semibold leading-snug mb-1 group-hover:underline">
    {title}
  </h3>
  <p class="text-sm text-ink-muted mb-3">
    {dateLabel} · {data.location}
  </p>
  <p class="text-sm leading-relaxed line-clamp-3">
    {description}
  </p>
  {isFallback && (
    <p class="text-xs text-ink-muted mt-2">{t(locale, 'common.english_only')}</p>
  )}
</a>
