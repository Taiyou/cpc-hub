{
  "name": "cpc-hub",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "fetch:youtube": "node scripts/fetch-youtube.mjs",
    "fetch:note": "node scripts/fetch-note.mjs",
    "fetch:arxiv": "node scripts/fetch-arxiv.mjs",
    "sync:papers": "node scripts/sync-papers-from-notion.mjs",
    "papers:pipeline": "node scripts/fetch-arxiv.mjs && node scripts/sync-papers-from-notion.mjs",
    "fetch:all": "node scripts/fetch-youtube.mjs && node scripts/fetch-note.mjs",
    "update:videos": "node scripts/fetch-youtube.mjs && astro build",
    "update:content": "pnpm fetch:all && pnpm papers:pipeline && astro build"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.4",
    "@notionhq/client": "^2.3.0",
    "astro": "^5.0.0",
    "tailwindcss": "^3.4.17"
  },
  "packageManager": "pnpm@11.0.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
