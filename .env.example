# YouTube Data API v3 key. Restrict to the YouTube Data API v3 only.
# Used by scripts/fetch-youtube.mjs. NEVER commit your real key.
YOUTUBE_API_KEY=

# Notion Internal Integration token (starts with `ntn_` or `secret_`).
# Get one from https://www.notion.so/profile/integrations
# The integration must be invited to the "CPC Papers" database page
# (open the DB -> ... menu -> Connections -> Add -> select the integration).
# Used by scripts/fetch-arxiv.mjs and scripts/sync-papers-from-notion.mjs.
NOTION_TOKEN=

# Notion Database ID (32-character hex, with or without dashes).
# Open the DB in Notion -> Share -> Copy link -> the ID is the path segment
# before `?v=...`. Example URL:
#   https://notion.so/workspace/<DB_ID>?v=<VIEW_ID>
NOTION_DB_ID=
